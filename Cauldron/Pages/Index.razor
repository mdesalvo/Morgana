@page "/"
@inject IChatStateService ChatStateService
@inject IConversationLifecycleService ConversationLifecycleService
@inject IStreamingService StreamingService
@inject SignalRService SignalRService
@inject ILandingMessageService LandingMessageService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Morgana - Magical AI Assistant</PageTitle>

<div class="chat-container">
    <!-- Header -->
    <div class="chat-header">
        <div class="header-content">

            <div class="header-avatar-wrapper @(ChatStateService.IsSending ? "sending" : "") @ChatStateService.GetAgentClass(ChatStateService.CurrentAgentName)">
                <div class="magic-glow"></div>
                <div class="magic-ring"></div>
                <span class="sparkle s1"></span>
                <span class="sparkle s2"></span>
                <span class="sparkle s3"></span>
                <span class="sparkle s4"></span>
                <span class="sparkle s5"></span>
                <span class="sparkle s6"></span>
                <img src="images/morgana-animated.gif"
                     alt="Morgana"
                     class="header-avatar"
                     style="border: 3px solid @ChatStateService.GetAvatarBorderColor(ChatStateService.CurrentAgentName);" />
            </div>

            <div class="header-info">
                <h1 style="color: @ChatStateService.GetAvatarBorderColor(ChatStateService.CurrentAgentName);">@ChatStateService.CurrentAgentName</h1>
                <span class="status @(ChatStateService.IsConnected ? "online" : "offline")"
                      role="status"
                      style="color: @(ChatStateService.IsConnected ? "#10b981" : "#ef4444");">
                    @(ChatStateService.IsConnected ? "Online" : "Offline")
                </span>
            </div>

            <button class="new-conversation-btn @(IsNewConversationButtonVisible ? "visible" : "hidden")"
                    @onclick="ShowConfirmModal"
                    aria-label="Start a new conversation"
                    title="Start a new conversation with Morgana">
                <span class="btn-icon" aria-hidden="true">✨</span>
                <span class="btn-text">New Conversation</span>
            </button>

        </div>
    </div>

    <!-- Messages Area -->
    <div class="messages-container" aria-live="polite" aria-relevant="additions">

        @if (ChatStateService.TemporaryMessages.Any())
        {
            <div class="temporary-messages-container" aria-live="assertive" aria-relevant="additions">
                @foreach (ChannelMessage temporaryMessage in ChatStateService.TemporaryMessages)
                {
                    <FadingMessage Message="@temporaryMessage"
                                   DurationSeconds="@(temporaryMessage.FadingMessageDurationSeconds ?? 10)"
                                   OnDismissed="@HandleMessageDismissed"/>
                }
            </div>
        }

        @if (ChatStateService.ChatMessages.Count == 0)
        {
            <!-- Loading state with magical animation -->
            <!-- Loader visible until first message arrives from backend (presentation or conversation history) -->
            <div class="magical-loader">
                <div class="magic-sparkle-core">
                    <div class="glow-core"></div>
                    <div class="glow-ring ring-1"></div>
                    <div class="glow-ring ring-2"></div>
                    <div class="glow-ring ring-3"></div>
                </div>
                <div class="sparkles-container">
                    <div class="sparkle sp1"></div>
                    <div class="sparkle sp2"></div>
                    <div class="sparkle sp3"></div>
                    <div class="sparkle sp4"></div>
                    <div class="sparkle sp5"></div>
                    <div class="sparkle sp6"></div>
                    <div class="sparkle sp7"></div>
                    <div class="sparkle sp8"></div>
                    <div class="sparkle sp9"></div>
                    <div class="sparkle sp10"></div>
                    <div class="sparkle sp11"></div>
                    <div class="sparkle sp12"></div>
                </div>
                <p class="loading-text">@(landingMessage)</p>
            </div>
        }
        else
        {
            <!-- Message list -->
            @foreach (ChatMessage chatMessage in ChatStateService.ChatMessages)
            {
                <div class="message @chatMessage.Role"
                     aria-label="@(chatMessage.Role == "user" ? "You" : chatMessage.AgentName)">
                    @if (chatMessage.Role == "assistant")
                    {
                        <!-- Agent avatar with dynamic border color -->
                        <img src="images/morgana-avatar.png"
                             alt="@chatMessage.AgentName"
                             class="message-avatar"
                             style="border: 2px solid @ChatStateService.GetAvatarBorderColor(chatMessage.AgentName);"/>
                    }
                    <div class="message-bubble @(chatMessage.IsStreaming ? "streaming" : "")">
                        @if (chatMessage.IsTyping)
                        {
                            <!-- Typing indicator (sparkles stars) -->
                            <div class="typing-indicator @(ChatStateService.IsSpecializedAgent(chatMessage.AgentName) ? "specialized" : "base")"
                                 role="status"
                                 aria-label="@(chatMessage.AgentName) is typing">
                                <span aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z"/></svg></span>
                                <span aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z"/></svg></span>
                                <span aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z"/></svg></span>
                            </div>
                        }
                        else
                        {
                            @* Message content (text) *@
                            <div class="message-text @(chatMessage.Type == MessageType.Presentation ? "completion-text" : "")">
                                @MarkdownRendererService.ToHtml(chatMessage.Text)
                            </div>

                            @* Rich card (if present) *@
                            @if (chatMessage.RichCard != null)
                            {
                                <RichCard Card="@chatMessage.RichCard" />
                            }

                            @* Quick replies (if present) *@
                            @if (chatMessage is { QuickReplies.Count: > 0, IsStreaming: false })
                            {
                                <QuickReplyButton Replies="@chatMessage.QuickReplies"
                                                  OnSelect="@((reply) => SelectQuickReplyAsync(reply, chatMessage))"
                                                  IsDisabled="@(chatMessage.SelectedQuickReplyId != null || chatMessage.IsLastHistoryMessage == false)"
                                                  SelectedReplyId="@chatMessage.SelectedQuickReplyId"/>
                            }

                            <!-- Message timestamp -->
                            <div class="message-time">@chatMessage.Timestamp.ToString("HH:mm")</div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <!-- Input Area -->
    <div class="input-container">
        <textarea
            @bind="inputText"
            @bind:event="oninput"
            @onkeyup="HandleKeyPressAsync"
            aria-label="Message input"
            placeholder="Consult @(ChatStateService.CurrentAgentName)..."
            rows="1"
            disabled="@IsTextareaDisabled"
            class="message-input @(ChatStateService.IsSpecializedAgent(ChatStateService.CurrentAgentName) ? "agent" : "morgana")"></textarea>
        <SendButton
            AgentName="@ChatStateService.CurrentAgentName"
            IsSending="@ChatStateService.IsSending"
            IsDisabled="@IsSendButtonDisabled"
            OnClick="SendMessageAsync" />
    </div>
</div>

<!-- Confirmation Modal for New Conversation -->
<ConfirmModal IsVisible="@showConfirmModal"
              Title="Start New Conversation?"
              Message="This will start a new conversation with Morgana. Your chat history will be lost. Are you sure you want to continue?"
              ConfirmText="Yes, start new"
              CancelText="No, stay here"
              OnConfirm="@ConfirmNewConversationAsync"
              OnCancel="@HideConfirmModal" />

@code {
    // =========================================================================
    // LOCAL UI STATE (not shared across components)
    // =========================================================================

    /// <summary>
    /// Current text input from the user (two-way bound to textarea).
    /// </summary>
    private string inputText = string.Empty;

    /// <summary>
    /// Landing message (waiting for Morgana presentation).
    /// </summary>
    private string landingMessage = string.Empty;

    /// <summary>
    /// Controls visibility of the new conversation confirmation modal.
    /// </summary>
    private bool showConfirmModal;

    // =========================================================================
    // LIFECYCLE
    // =========================================================================

    /// <summary>
    /// Blazor lifecycle method called when component is initialized.
    /// Sets up SignalR connection and subscribes to events.
    /// </summary>
    /// <returns>Task representing the async initialization</returns>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize landing message
            landingMessage = LandingMessageService.GetLandingMessage();

            // Subscribe to streaming state changes for UI re-render
            StreamingService.OnStateChanged += () => InvokeAsync(StateHasChanged);

            // Start SignalRService connection
            await SignalRService.StartAsync();
            ChatStateService.IsConnected = SignalRService.IsConnected;

            // Subscribe to events (message received, streaming chunks for progressive rendering, connection state changes)
            SignalRService.OnMessageReceived += HandleMessageReceivedAsync;
            SignalRService.OnStreamChunkReceived += HandleStreamChunkReceivedAsync;
            SignalRService.OnConnectionStateChanged += (connected) =>
            {
                ChatStateService.IsConnected = connected;
                InvokeAsync(StateHasChanged);
            };

            if (!ChatStateService.HasCheckedStorage)
            {
                ChatStateService.HasCheckedStorage = true;

                try
                {
                    // Check ProtectedLocalStorage for saved conversation ID
                    string? savedConversationId = await ConversationLifecycleService.GetSavedConversationIdAsync();

                    if (!string.IsNullOrEmpty(savedConversationId))
                        await ConversationLifecycleService.ResumeConversationAsync(savedConversationId);
                    else
                        await ConversationLifecycleService.StartConversationAsync();

                    ChatStateService.IsInitialized = true;
                    ChatStateService.ClearErrorMessages();
                }
                catch (Exception ex)
                {
                    ChatStateService.AddErrorBanner($"Initialization error: {ex.Message}", "initialization_failed", 20);
                }
                finally
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception ex)
        {
            ChatStateService.AddErrorBanner($"Critical initialization error: {ex.Message}", "critical_initialization_failed", 30);
            await InvokeAsync(StateHasChanged);
        }
    }

    // =========================================================================
    // MESSAGE HANDLING
    // =========================================================================

    /// <summary>
    /// Sends a user message to Morgana backend via REST API.
    /// Adds user message and typing indicator to UI, then waits for agent response via SignalR.
    /// </summary>
    /// <returns>Task representing the async send operation</returns>
    private async Task SendMessageAsync()
    {
        // Validate input
        if (string.IsNullOrWhiteSpace(inputText) || ChatStateService.IsSending || !ChatStateService.IsConnected)
            return;

        string messageText = inputText.Trim();
        inputText = string.Empty;
        ChatStateService.IsSending = true;

        // Add user message to UI
        ChatStateService.AddUserMessage(messageText);

        // Add typing indicator
        ChatStateService.AddTypingIndicator();
        StateHasChanged();

        // Send message to backend
        if (!await ConversationLifecycleService.SendMessageAsync(messageText))
            await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Handles incoming messages from SignalR with strongly-typed DTO.
    /// Removes typing indicator, updates agent state, and adds message to UI.
    /// </summary>
    /// <param name="signalrMessage">Strongly-typed SignalR message DTO containing all message data</param>
    /// <returns>Task representing the async message handling</returns>
    private async Task HandleMessageReceivedAsync(ChannelMessage message)
    {
        try
        {
            // Temporary messages (system warnings, errors) - display as banners
            if (string.Equals(message.MessageType, "system_warning", StringComparison.OrdinalIgnoreCase)
                || string.Equals(message.MessageType, "error", StringComparison.OrdinalIgnoreCase))
            {
                ChatStateService.TemporaryMessages.Add(message);
                await InvokeAsync(StateHasChanged);
                return;
            }

            // Verify message is for this conversation
            if (ChatStateService.ConversationId != message.ConversationId)
                return;

            // PATH 1: Finalize active streaming
            if (StreamingService.IsStreaming)
            {
                StreamingService.FinalizeStreaming(message);
                ChatStateService.UpdateAgentFromMessage(message);
                ChatStateService.AddCompletionMessageIfNeeded(message);
                ChatStateService.IsSending = false;
                await InvokeAsync(StateHasChanged);
                return;
            }

            // PATH 2: Non-streaming message (presentation, history restore)
            ChatStateService.RemoveTypingIndicator();
            ChatStateService.UpdateAgentFromMessage(message);

            // Add main agent message
            ChatStateService.ChatMessages.Add(new ChatMessage
            {
                ConversationId = message.ConversationId,
                Text = message.Text,
                Role = "assistant",
                Timestamp = message.Timestamp,
                QuickReplies = message.QuickReplies,
                AgentName = message.AgentName ?? "Morgana",
                AgentCompleted = false,
                RichCard = message.RichCard
            });

            // Add completion message if needed (shared logic)
            ChatStateService.AddCompletionMessageIfNeeded(message);

            // Reset sending state - message received via SignalR
            ChatStateService.IsSending = false;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in HandleMessageReceived: {ex.Message}");
        }
    }

    // =========================================================================
    // STREAMING HANDLERS
    // =========================================================================

    /// <summary>
    /// Handles incoming streaming chunks from SignalR.
    /// Starts streaming mode if needed and buffers chunks for typewriter effect.
    /// </summary>
    /// <param name="chunkText">Partial response text to append</param>
    /// <returns>Task representing the async chunk handling</returns>
    private async Task HandleStreamChunkReceivedAsync(string chunkText)
    {
        try
        {
            await StreamingService.HandleChunkAsync(chunkText);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in HandleStreamChunkReceived: {ex.Message}");
        }
    }

    // =========================================================================
    // UI INTERACTION HANDLERS
    // =========================================================================

    /// <summary>
    /// Handles keyboard events in textarea (Enter to send, Shift+Enter for newline).
    /// </summary>
    /// <param name="e">Keyboard event args</param>
    /// <returns>Task representing the async key handling</returns>
    private async Task HandleKeyPressAsync(KeyboardEventArgs e)
    {
        // Send message on Enter (without Shift)
        if (e is { Key: "Enter", ShiftKey: false })
            await SendMessageAsync();
    }

    /// <summary>
    /// Handles quick reply button selection.
    /// Marks the selected reply, disables all buttons, and sends the reply value as user message.
    /// </summary>
    /// <param name="reply">Selected quick reply definition</param>
    /// <param name="message">Message containing the quick replies</param>
    /// <returns>Task representing the async selection handling</returns>
    private async Task SelectQuickReplyAsync(QuickReply reply, ChatMessage message)
    {
        // Prevent multiple selections
        if (message.SelectedQuickReplyId != null)
            return;

        // Mark as selected and update UI
        message.SelectedQuickReplyId = reply.Id;
        StateHasChanged();

        // Visual feedback delay
        await Task.Delay(250);

        // Send the quick reply value as user message
        inputText = reply.Value;
        await SendMessageAsync();
    }

    /// <summary>
    /// Shows the confirmation modal for starting a new conversation.
    /// </summary>
    private void ShowConfirmModal()
    {
        showConfirmModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Hides the confirmation modal without taking action.
    /// </summary>
    private void HideConfirmModal()
    {
        showConfirmModal = false;
        StateHasChanged();
    }

    /// <summary>
    /// Handles the confirmation action - hides modal and starts new conversation.
    /// </summary>
    private async Task ConfirmNewConversationAsync()
    {
        showConfirmModal = false;
        StateHasChanged();

        await ConversationLifecycleService.ClearConversationAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private void HandleMessageDismissed(ChannelMessage message)
    {
        ChatStateService.DismissTemporaryMessage(message);
        StateHasChanged();
    }

    // =========================================================================
    // UI STATE QUERIES
    // =========================================================================

    private bool IsSendButtonDisabled =>
        !ChatStateService.IsConnected ||
        ChatStateService.IsSending ||
        string.IsNullOrWhiteSpace(inputText) ||
        !ChatStateService.IsInitialized ||
        ChatStateService.HasActiveQuickReplies() ||
        ChatStateService.HasTypingIndicator();

    private bool IsNewConversationButtonVisible =>
        ChatStateService.IsConnected
        && ChatStateService.IsInitialized
        && ChatStateService.HasCheckedStorage
        && !string.IsNullOrWhiteSpace(ChatStateService.ConversationId)
        && ChatStateService.ChatMessages.Count > 0;

    private bool IsTextareaDisabled =>
        !ChatStateService.IsConnected ||
        ChatStateService.IsSending ||
        !ChatStateService.IsInitialized ||
        ChatStateService.HasActiveQuickReplies() ||
        ChatStateService.HasTypingIndicator();

    // =========================================================================
    // CLEANUP
    // =========================================================================

    /// <summary>
    /// Disposes component resources.
    /// Unsubscribes from SignalR events and stops connection.
    /// </summary>
    /// <returns>ValueTask representing the async dispose operation</returns>
    public async ValueTask DisposeAsync()
    {
        // Unsubscribe from events
        SignalRService.OnMessageReceived -= HandleMessageReceivedAsync;
        SignalRService.OnStreamChunkReceived -= HandleStreamChunkReceivedAsync;
        StreamingService.OnStateChanged -= () => InvokeAsync(StateHasChanged);

        await StreamingService.DisposeAsync();
        await SignalRService.StopAsync();
    }
}