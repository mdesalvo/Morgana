@namespace Cauldron.Components

<div class="rich-card">
    @* Card header *@
    <div class="rich-card-header">
        <h3 class="rich-card-title">@Card.Title</h3>
        @if (!string.IsNullOrWhiteSpace(Card.Subtitle))
        {
            <p class="rich-card-subtitle">@Card.Subtitle</p>
        }
    </div>

    @* Card body with components *@
    <div class="rich-card-body">
        @foreach (CardComponent component in Card.Components)
        {
            <RichCardComponent Component="@component" Depth="1" />
        }
    </div>
</div>

@code {
    /// <summary>
    /// The rich card data to render.
    /// </summary>
    [Parameter]
    public Cauldron.Messages.Contracts.RichCard? Card { get; set; }

    private bool _sanitized;

    protected override void OnParametersSet()
    {
        if (Card != null && !_sanitized)
        {
            MarkdownRendererService.SanitizeRichCard(Card);
            _sanitized = true;
        }
    }
}
