@namespace Cauldron.Components

<div class="rich-card">
    @* Card header *@
    <div class="rich-card-header">
        <h3 class="rich-card-title">@MarkdownRendererService.ToInlineHtml(Card!.Title)</h3>
        @if (!string.IsNullOrWhiteSpace(Card.Subtitle))
        {
            <p class="rich-card-subtitle">@MarkdownRendererService.ToInlineHtml(Card.Subtitle)</p>
        }
    </div>

    @* Card body with components *@
    <div class="rich-card-body">
        @foreach (CardComponent component in Card.Components)
        {
            <RichCardComponent Component="@component" Depth="1" />
        }
    </div>
</div>

@code {
    /// <summary>
    /// The rich card data to render. Leaf components render inline Markdown in their text
    /// fields via <see cref="MarkdownRendererService.ToInlineHtml"/>, so the card is passed
    /// through untouched — no pre-sanitization step that would strip that Markdown away.
    /// </summary>
    [Parameter]
    public Morgana.Contracts.RichCard? Card { get; set; }
}
