@namespace Cauldron.Components

<div class="rich-card-key-value @(Component.Emphasize ? "rich-card-key-value-emphasized" : "")">
    <span class="rich-card-key">@MarkdownRendererService.ToInlineHtml(Component.Key):</span>
    <span class="rich-card-value">@MarkdownRendererService.ToInlineHtml(Component.Value)</span>
</div>

@code {
    [Parameter]
    public required KeyValueComponent Component { get; set; }
}
