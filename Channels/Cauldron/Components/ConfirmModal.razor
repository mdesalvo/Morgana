@namespace Cauldron.Components

@* Confirmation modal component with magical Morgana theme *@

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="HandleBackdropClick">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="magical-icon">✨</div>
                <h3>@Title</h3>
            </div>

            <div class="modal-body">
                <p>@Message</p>
            </div>

            <div class="modal-actions">
                <button class="modal-btn cancel" @onclick="OnCancel">
                    <span class="btn-icon">✕</span>
                    <span>@CancelText</span>
                </button>
                @if (ShowSeedOption)
                {
                    @* Only surfaced when the current conversation is dust-exhausted: start
                       fresh but carry a compressed memory of this one. Distinct from the
                       plain confirm (which forgets everything). *@
                    <button class="modal-btn seed" @onclick="OnSeedContinue">
                        <span class="btn-icon">✨</span>
                        <span>@SeedText</span>
                    </button>
                }
                <button class="modal-btn confirm" @onclick="OnConfirm">
                    <span class="btn-icon">✓</span>
                    <span>@ConfirmText</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Title { get; set; } = "Confirm Action";

    [Parameter]
    public string Message { get; set; } = "Are you sure?";

    [Parameter]
    public string ConfirmText { get; set; } = "Yes";

    [Parameter]
    public string CancelText { get; set; } = "No";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    /// <summary>
    /// When true, a third action is shown: start a new conversation that remembers the
    /// current (dust-exhausted) one. Off by default — only the dust lockout enables it.
    /// </summary>
    [Parameter]
    public bool ShowSeedOption { get; set; }

    /// <summary>Label for the seed-continue action (shown only when <see cref="ShowSeedOption"/>).</summary>
    [Parameter]
    public string SeedText { get; set; } = "Continue, remembering this one";

    /// <summary>Invoked when the user picks the seed-continue action.</summary>
    [Parameter]
    public EventCallback OnSeedContinue { get; set; }

    [Parameter]
    public bool CloseOnBackdrop { get; set; } = true;

    private void HandleBackdropClick()
    {
        if (CloseOnBackdrop)
        {
            OnCancel.InvokeAsync();
        }
    }
}